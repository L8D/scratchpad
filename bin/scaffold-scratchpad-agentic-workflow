#!/usr/bin/env bash
WORKTREE_ROOT=$(dirname $(dirname $PWD))
ISSUE_ID="$(awk '{print $1}')"
ISSUE="$(kota tickets read "$ISSUE_ID")"
STATUS="$(echo "$ISSUE" | jq -r '.status')"
if [ "$STATUS" = "Backlog" ] || [ "$STATUS" = "Unstarted" ]; then
  kota tickets update "$ISSUE_ID" --status "${KOTA_STATUS_STARTED:-Started}" >/dev/null 2>&1
fi
BRANCH_NAME="$(echo "$ISSUE" | jq -r '.branchName')"
TITLE="$(echo "$ISSUE" | jq -r '.title')"
DESCRIPTION="$(echo "$ISSUE" | jq -r '.description')"
echo "# $BRANCH_NAME {{{"
echo "pad://$BRANCH_NAME # {{{"
echo "ollo claude $ISSUE_ID -- --permission-mode plan \"\$(cat <<'PROMPT'"
echo "$ISSUE_ID" "$TITLE"
echo
echo "$DESCRIPTION"
echo PROMPT
echo ")\""
echo "# }}}"
echo

echo "pad://decompose-$BRANCH_NAME # {{{"
echo "ollo claude $ISSUE_ID -- --permission-mode plan '/ollo:decompose'"
echo "# }}}"
echo

echo "pad://ralph-$BRANCH_NAME # {{{"
echo "ollo create-subtasks-from-decomposition-plan --from-ticket $ISSUE_ID"
if [ "${VIM_SCRATCHPAD_WORKTREES_ENABLED:-}" = "true" ]; then
  echo 'ollo use-worktree '$ISSUE_ID' $(git-spice top --dry-run)'
  echo "cd \$(branch-working-directory $BRANCH_NAME)"
  echo "ollo ralph"
  echo 'pm2 kill'
  echo 'docker compose down'
  echo 'cd '$WORKTREE_ROOT/worktrees/main' && { WT=$(branch-working-directory '$BRANCH_NAME'); if [ -z "$(git -C "$WT" status --porcelain)" ]; then git worktree remove "$WT"; else echo "Worktree is dirty, skipping removal"; fi; }'
else
  echo "[ \"\$(git rev-parse --abbrev-ref HEAD)\" != \"$BRANCH_NAME\" ] && git-spice branch create --no-commit $BRANCH_NAME"
  echo "ollo ralph"
fi
echo "# }}}"
echo
echo .git/index
echo capture "$ISSUE_ID"
echo "git-spice branch fold --no-prompt"
echo "# }}}"
