#!/usr/bin/env zsh
# Appends a command to ~/.zsh_history_inf in zsh extended history format.
# Usage: zsh-history-append "command text"

local cmd="$1"
[[ -z "$cmd" ]] && exit 0

local ts
ts=$(date +%s)

# For multi-line commands, zsh extended history uses backslash + newline continuation
local escaped=${cmd//$'\n'/$'\\\n'}

printf '%s\n' ": ${ts}:0;${escaped}" >> ~/.zsh_history_inf
