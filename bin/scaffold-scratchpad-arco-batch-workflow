#!/usr/bin/env bash
set -euo pipefail

# Read ticket IDs from stdin into a simple array
TICKETS=()
while IFS= read -r line || [ -n "$line" ]; do
  [ -z "$line" ] && continue
  TICKETS[${#TICKETS[@]}]="$line"
done

N=${#TICKETS[@]}

if [ "$N" -eq 0 ]; then
  echo "Error: no ticket IDs provided on stdin" >&2
  exit 1
fi

# Emit chunk selection + now-resolution (runs at execution time)
echo 'CHUNK_TIME=$(arco select-chunk)'
echo '[ "$CHUNK_TIME" = "now" ] && CHUNK_TIME=$(date -u +"%Y-%m-%dT%H:%M:%SZ")'
echo ''

# Emit one commit block per ticket
i=0
while [ "$i" -lt "$N" ]; do
  i=$((i + 1))
  TICKET_ID="${TICKETS[$((i - 1))]}"
  TICKET_TITLE=$(kota tickets read "$TICKET_ID" | jq -r '.title')
  echo "# $TICKET_ID $TICKET_TITLE"
  echo "arco commit --until \"\$CHUNK_TIME\" --split \"$i/$N\" --ticket-id \"$TICKET_ID\" <<'EOF' && arco publish \"$TICKET_ID\""
  echo "pbpaste | jq -r '.structured_output.\"$TICKET_ID\".text'"
  echo "EOF"
  echo ""
done
